<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blog Mongo | Contact</title>
    <link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: { sans: ['Manrope', 'ui-sans-serif', 'system-ui'] }
          }
        }
      };
    </script>
  </head>
  <body class="min-h-screen bg-[#eef7fc] font-sans text-[#163752]">
    <div class="absolute inset-x-0 top-0 -z-10 h-[420px] bg-[radial-gradient(circle_at_20%_0%,#d8f0ff,transparent_48%),radial-gradient(circle_at_80%_0%,#e1f4ff,transparent_52%)]"></div>

    <%- include('layouts/navbar') %>

    <main class="mx-auto max-w-5xl px-4 py-8 sm:px-6 lg:px-8">
      <section class="grid gap-6 lg:grid-cols-[1.25fr_1fr]">
        <article class="rounded-[28px] border border-[#d7ebf7] bg-white p-6 shadow-[0_18px_40px_-30px_rgba(44,116,160,0.45)] sm:p-8">
          <h1 class="text-3xl font-extrabold text-[#12344e]">Contact</h1>
          <p class="mt-3 text-[#4f7188]">Tu as une question ou une idée de sujet robot/IA ?</p>
          <div class="mt-6 space-y-3 text-sm">
            <div class="rounded-xl border border-[#d2e9f7] bg-[#f4fbff] px-4 py-3"><span class="font-bold text-[#2f7dac]">Email:</span> hello@blogmongo.dev</div>
            <div class="rounded-xl border border-[#d2e9f7] bg-[#f4fbff] px-4 py-3"><span class="font-bold text-[#2f7dac]">Discord:</span> tech-bots-community</div>
            <div class="rounded-xl border border-[#d2e9f7] bg-[#f4fbff] px-4 py-3"><span class="font-bold text-[#2f7dac]">Lieu:</span> Paris, France</div>
          </div>
        </article>

        <aside class="rounded-[28px] border border-[#d7ebf7] bg-white p-5 shadow-[0_18px_40px_-30px_rgba(44,116,160,0.45)]">
          <img src="/assets/img/robotsosuris.png" alt="Robot contact" class="w-full rounded-xl border border-[#d2e9f7] bg-[#f7fcff] object-contain p-2" />
          <div class="mt-4 rounded-xl bg-[#daf1ff] px-4 py-3 text-sm text-[#2b7eaf]">💬 On répond rapidement aux messages.</div>
        </aside>
      </section>
    </main>
  </body>
</html>
