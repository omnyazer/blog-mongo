<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blog Mongo | Home</title>
    <link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: { sans: ['Manrope', 'ui-sans-serif', 'system-ui'] }
          }
        }
      };
    </script>
  </head>
  <body class="min-h-screen bg-[#ecf6fc] font-sans text-[#17364f]">
    <%- include('layouts/navbar') %>

    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-[30px] border border-[#d6e8f5] bg-[#e9f4fb] p-5 sm:p-7">
        <div class="pointer-events-none absolute -left-2 top-20 h-28 w-28 rounded-full border-[8px] border-[#d9ebf7]"></div>
        <div class="pointer-events-none absolute right-6 top-6 h-24 w-24 rounded-full border-[8px] border-[#d9ebf7]"></div>

        <section class="relative rounded-3xl border border-[#cde3f3] bg-white p-5 shadow-[0_20px_35px_-28px_rgba(53,114,156,0.45)] sm:p-6">
          <h2 class="mb-3 text-2xl font-extrabold tracking-tight">ACCUEIL DU BLOG</h2>

          <div class="rounded-2xl border border-[#d7eaf6] bg-[#f8fcff] p-4">
            <div class="mb-4 flex items-center gap-3 border-b border-[#e3f1fa] pb-3">
              <img src="/assets/img/logo.png" alt="Logo" class="h-8 w-8 rounded-full object-cover" />
              <span class="text-sm font-extrabold text-[#12344e]">TECH & BOTS</span>
              <span class="ml-auto rounded-full bg-[#2fa8ef] px-3 py-1 text-xs font-bold text-white">Accueil</span>
            </div>

            <div class="grid gap-5 lg:grid-cols-[1fr_1.1fr] lg:items-center">
              <div>
                <h3 class="text-3xl font-extrabold leading-tight text-[#12344e] sm:text-4xl">LE FUTUR EST ICI :<br />EXPLOREZ LE MONDE DES ROBOTS & DE L'IA !</h3>
                <p class="mt-3 text-sm text-[#4e6f86] sm:text-base">Découvrez les dernières innovations, tutoriels et actualités sur la robotique, l'IA et le code.</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  <a href="/list" class="inline-flex rounded-full bg-[#2fa8ef] px-4 py-2 text-xs font-extrabold uppercase tracking-wider text-white">Voir les articles</a>
                  <a href="<%= loggedIn ? '/post/new' : '/auth/login' %>" class="inline-flex rounded-full bg-[#f1f8ff] px-4 py-2 text-xs font-extrabold uppercase tracking-wider text-[#2a83b7] ring-1 ring-[#cce4f4]">Créer un article</a>
                </div>
              </div>
              <img src="/assets/img/RobotHérosPrincipal.png" alt="Robot hero" class="w-full rounded-xl border border-[#d2e8f7] bg-white object-contain p-2" />
            </div>
          </div>

          <img src="/assets/img/IconeBulle.png" alt="Bulle" class="absolute -left-6 top-28 hidden w-14 md:block" />
          <img src="/assets/img/iconebULLE2.png" alt="Bulle" class="absolute -right-4 top-10 hidden w-16 md:block" />
        </section>

        <section class="mt-7 grid gap-6 lg:grid-cols-2">
          <article class="relative rounded-3xl border border-[#cde3f3] bg-white p-4 shadow-[0_20px_35px_-28px_rgba(53,114,156,0.45)] sm:p-5">
            <h2 class="mb-3 text-2xl font-extrabold tracking-tight">ARTICLE DE BLOG </h2>

            <div class="rounded-2xl border border-[#d7eaf6] bg-[#f8fcff] p-4">
              <h3 class="text-2xl font-extrabold leading-tight text-[#12344e]">Comment l’IA transforme la robotique moderne</h3>
              <p class="mt-2 text-sm text-[#4e6f86]">
                Dans cet article exemple, on découvre comment l’intelligence artificielle aide les robots à apprendre plus vite,
                reconnaître leur environnement et exécuter des tâches précises en autonomie.
              </p>
              <img src="/assets/img/RobotIA.png" alt="Illustration article" class="mt-4 w-full rounded-xl border border-[#d2e8f7] bg-white object-contain p-2" />
              <a href="/post/example-ia" class="mt-4 inline-flex rounded-full bg-[#2fa8ef] px-4 py-2 text-xs font-extrabold uppercase tracking-wider text-white">Lire plus d'articles IA</a>
            </div>

            <img src="/assets/img/IconeBulle.png" alt="Bulle" class="absolute -right-5 top-32 hidden w-14 md:block" />
          </article>

          <section class="rounded-3xl border border-[#cde3f3] bg-white p-5 shadow-[0_20px_35px_-28px_rgba(53,114,156,0.45)]">
            <div class="mb-4 flex items-center justify-between gap-4">
              <h2 class="text-2xl font-extrabold">BLOG</h2>
              <form action="/list" method="GET" class="flex items-center gap-2">
                <input type="text" name="search" placeholder="Recherche" class="w-44 rounded-xl border border-[#cfe6f5] bg-[#f7fcff] px-3 py-2 text-sm text-[#29506d] outline-none focus:border-[#51b4e8]" />
                <button type="submit" class="rounded-xl bg-[#2fa8ef] px-3 py-2 text-xs font-bold text-white">Go</button>
              </form>
            </div>

            <% if (blogPosts && blogPosts.length > 0) { %>
              <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                <a href="/post/example-ia" class="overflow-hidden rounded-xl border border-[#cfe6f5] bg-[#f8fcff]">
                  <img src="/assets/img/RobotIA.png" alt="robot" class="h-28 w-full object-cover" />
                  <div class="p-3">
                    <h3 class="line-clamp-1 text-sm font-extrabold text-[#133a56]">Comment l’IA transforme la robotique moderne</h3>
                    <p class="mt-1 line-clamp-2 text-xs text-[#4f7188]">Article exemple IA: vision intelligente, apprentissage et automatisation.</p>
                    <p class="mt-2 text-[11px] font-semibold text-[#2a83b7]">Article exemple</p>
                  </div>
                </a>
                <% blogPosts.forEach((post, index) => { %>
                  <article class="overflow-hidden rounded-xl border border-[#cfe6f5] bg-[#f8fcff]">
                    <a href="/post/<%= post._id %>" class="block">
                      <img src="<%= post.image ? ('/images/' + post.image) : '/assets/img/RobotNeutre1.png' %>" alt="robot" class="h-28 w-full object-cover" />
                      <div class="p-3">
                        <h3 class="line-clamp-1 text-sm font-extrabold text-[#133a56]"><%= post.title %></h3>
                        <p class="mt-1 line-clamp-2 text-xs text-[#4f7188]"><%= post.body %></p>
                        <% if (post.userid) { %>
                          <p class="mt-2 text-[11px] font-semibold text-[#2a83b7]">Par <%= post.userid.username %></p>
                        <% } %>
                      </div>
                    </a>
                    <% if (loggedIn && post.userid && String(loggedIn) === String(post.userid._id)) { %>
                      <form action="/posts/delete/<%= post._id %>" method="POST" class="px-3 pb-3">
                        <button type="submit" class="w-full rounded-lg bg-[#ef8f59] px-3 py-2 text-xs font-bold text-white hover:bg-[#de7b44]" onclick="return confirm('Supprimer ce post ?');">Supprimer</button>
                      </form>
                    <% } %>
                  </article>
                <% }) %>
              </div>
            <% } else { %>
              <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                <a href="/list?search=IA" class="overflow-hidden rounded-xl border border-[#cfe6f5] bg-[#f8fcff]">
                  <img src="/assets/img/RobotIA.png" alt="robot" class="h-28 w-full object-cover" />
                  <div class="p-3">
                    <h3 class="line-clamp-1 text-sm font-extrabold text-[#133a56]">Comment l’IA transforme la robotique moderne</h3>
                    <p class="mt-1 line-clamp-2 text-xs text-[#4f7188]">Article exemple IA: vision intelligente, apprentissage et automatisation.</p>
                    <p class="mt-2 text-[11px] font-semibold text-[#2a83b7]">Article exemple</p>
                  </div>
                </a>
              </div>
            <% } %>
          </section>
        </section>
      </div>
    </main>
  </body>
</html>
