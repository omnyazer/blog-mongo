<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blog Mongo | Create</title>
    <link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: { sans: ['Manrope', 'ui-sans-serif', 'system-ui'] }
          }
        }
      };
    </script>
  </head>
  <body class="min-h-screen bg-[#eef7fc] font-sans text-[#163752]">
    <div class="absolute inset-x-0 top-0 -z-10 h-[420px] bg-[radial-gradient(circle_at_20%_0%,#d8f0ff,transparent_48%),radial-gradient(circle_at_80%_0%,#e1f4ff,transparent_52%)]"></div>

    <%- include('layouts/navbar') %>

    <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
      <section class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
        <aside class="space-y-4">
          <div class="rounded-[24px] border border-[#d7ebf7] bg-white p-5 shadow-[0_14px_34px_-28px_rgba(44,116,160,0.42)]">
            <img src="/assets/img/%C3%89critureBlog.png" alt="Ecriture blog" class="w-full rounded-xl border border-[#d2e9f7]" />
            <p class="mt-4 text-sm text-[#4f7188]">Trouve une idée, structure ton message, puis publie ton article pour le partager avec la communauté.</p>
          </div>
          <div class="rounded-[24px] border border-[#d7ebf7] bg-[#daf1ff] p-5">
            <p class="text-sm font-semibold text-[#2b7eaf]">💬 "Écris un contenu simple, clair et utile."</p>
          </div>
        </aside>

        <div class="rounded-[28px] border border-[#d7ebf7] bg-white p-6 shadow-[0_18px_40px_-30px_rgba(44,116,160,0.45)] sm:p-8">
          <h1 class="text-3xl font-extrabold text-[#12344e]">Create New Post</h1>
          <p class="mt-2 text-[#4f7188]">Use this form to create a new blog post.</p>

          <% if (errors && errors.length > 0) { %>
            <ul class="mt-5 space-y-2">
              <% for (let i = 0; i < errors.length; i++) { %>
                <li class="rounded-xl border border-[#f1c8c8] bg-[#fff1f1] px-4 py-3 text-sm text-[#b95353]"><%= errors[i] %></li>
              <% } %>
            </ul>
          <% } %>

          <form action="/posts/store" method="POST" enctype="multipart/form-data" class="mt-6 space-y-5">
            <div>
              <label for="title" class="mb-2 block text-sm font-bold text-[#2d5775]">Title</label>
              <input id="title" type="text" name="title" placeholder="Enter your title..." value="<%= title %>" class="w-full rounded-xl border border-[#cfe6f5] bg-[#f7fcff] px-4 py-3 text-[#20455f] outline-none transition focus:border-[#57b5e8] focus:ring-2 focus:ring-[#bae6ff]" />
            </div>

            <div>
              <label for="description" class="mb-2 block text-sm font-bold text-[#2d5775]">Description</label>
              <textarea id="description" name="body" placeholder="Enter your description..." style="height: 12rem" class="w-full rounded-xl border border-[#cfe6f5] bg-[#f7fcff] px-4 py-3 text-[#20455f] outline-none transition focus:border-[#57b5e8] focus:ring-2 focus:ring-[#bae6ff]"><%= body %></textarea>
            </div>

            <div>
              <label for="image" class="mb-2 block text-sm font-bold text-[#2d5775]">Image</label>
              <input type="file" name="image" id="image" class="w-full rounded-xl border border-dashed border-[#c0dff1] bg-[#f7fcff] px-4 py-3 text-sm text-[#58758c] file:mr-4 file:rounded-lg file:border-0 file:bg-[#58b8e8] file:px-4 file:py-2 file:font-semibold file:text-white hover:file:bg-[#419fd0]" />
            </div>

            <button id="submitButton" type="submit" class="inline-flex rounded-xl bg-[#58b8e8] px-6 py-3 text-sm font-extrabold uppercase tracking-[0.08em] text-white transition hover:bg-[#419fd0]">Create</button>
          </form>
        </div>
      </section>
    </main>
  </body>
</html>
