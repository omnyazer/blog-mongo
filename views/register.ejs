<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blog Mongo | Register</title>
    <link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: { sans: ['Manrope', 'ui-sans-serif', 'system-ui'] }
          }
        }
      };
    </script>
  </head>
  <body class="min-h-screen bg-[#eef7fc] font-sans text-[#163752]">
    <div class="absolute inset-x-0 top-0 -z-10 h-[420px] bg-[radial-gradient(circle_at_20%_0%,#d8f0ff,transparent_48%),radial-gradient(circle_at_80%_0%,#e1f4ff,transparent_52%)]"></div>

    <%- include('layouts/navbar') %>

    <main class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
      <section class="grid gap-8 lg:grid-cols-[1.2fr_1fr]">
        <div class="rounded-[32px] border border-[#d7ebf7] bg-white p-10 shadow-[0_18px_40px_-30px_rgba(44,116,160,0.45)] sm:p-12">
          <h1 class="text-5xl font-extrabold text-[#12344e] sm:text-6xl">Register</h1>

          <% if (errors && errors.length > 0) { %>
            <ul class="mt-5 space-y-2">
              <% for (let i = 0; i < errors.length; i++) { %>
                <li class="rounded-xl border border-[#f1c8c8] bg-[#fff1f1] px-4 py-3 text-sm text-[#b95353]"><%= errors[i] %></li>
              <% } %>
            </ul>
          <% } %>

          <form action="/users/register" method="POST" class="mt-10 space-y-7">
            <div>
              <label for="username" class="mb-2 block text-lg font-bold text-[#2d5775]">Username</label>
              <input type="text" name="username" id="username" value="<%= username %>" class="w-full rounded-xl border border-[#cfe6f5] bg-[#f7fcff] px-5 py-5 text-lg text-[#20455f] outline-none transition focus:border-[#57b5e8] focus:ring-2 focus:ring-[#bae6ff]" />
            </div>

            <div>
              <label for="password" class="mb-2 block text-lg font-bold text-[#2d5775]">Password</label>
              <input type="password" name="password" id="password" value="<%= password %>" class="w-full rounded-xl border border-[#cfe6f5] bg-[#f7fcff] px-5 py-5 text-lg text-[#20455f] outline-none transition focus:border-[#57b5e8] focus:ring-2 focus:ring-[#bae6ff]" />
            </div>

            <button type="submit" class="inline-flex rounded-xl bg-[#58b8e8] px-9 py-4 text-lg font-extrabold text-white transition hover:bg-[#419fd0]">Register</button>
          </form>
        </div>

        <aside class="rounded-[32px] border border-[#d7ebf7] bg-white p-8 shadow-[0_18px_40px_-30px_rgba(44,116,160,0.45)]">
          <img src="/assets/img/ImageRegister.png" alt="Robot register" class="w-full rounded-xl border border-[#d2e9f7] bg-[#f7fcff] object-contain p-2" />
          <p class="mt-4 text-base text-[#4f7188]">🛠️ Crée ton compte pour rejoindre la communauté Tech & Bots.</p>
        </aside>
      </section>
    </main>
  </body>
</html>
