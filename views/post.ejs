<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blog Mongo | Post</title>
    <link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: { sans: ['Manrope', 'ui-sans-serif', 'system-ui'] }
          }
        }
      };
    </script>
  </head>
  <body class="min-h-screen bg-[#eef7fc] font-sans text-[#163752]">
    <div class="absolute inset-x-0 top-0 -z-10 h-[420px] bg-[radial-gradient(circle_at_20%_0%,#d8f0ff,transparent_48%),radial-gradient(circle_at_80%_0%,#e1f4ff,transparent_52%)]"></div>

    <%- include('layouts/navbar') %>
    <% const headerImage = (typeof customHeaderImage !== 'undefined' && customHeaderImage) ? customHeaderImage : ((typeof blogPost !== 'undefined' && blogPost && blogPost.image) ? `/images/${blogPost.image}` : '/assets/img/robot-hero.svg'); %>

    <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
      <section class="overflow-hidden rounded-[28px] border border-[#d7ebf7] bg-white shadow-[0_18px_40px_-30px_rgba(44,116,160,0.45)]">
        <div class="border-b border-[#e3f1fa] bg-[#f6fbff] p-4 sm:p-6">
          <p class="inline-flex rounded-full bg-[#e8f6ff] px-3 py-1 text-xs font-bold uppercase tracking-[0.15em] text-[#3698d2]">Article de Blog (Single Post)</p>
        </div>

        <div class="grid gap-0 lg:grid-cols-[1.2fr_1fr]">
          <div class="p-5 sm:p-8">
            <% if (typeof blogPost !== 'undefined' && blogPost) { %>
              <h1 class="text-2xl font-extrabold leading-tight text-[#12344e] sm:text-4xl"><%= blogPost.title %></h1>
              <h2 class="mt-3 text-base text-[#4f7188]"><%= blogPost.body %></h2>
            <% } else { %>
              <h1 class="text-2xl font-extrabold text-[#12344e] sm:text-4xl">Post introuvable</h1>
              <h2 class="mt-3 text-base text-[#4f7188]">Aucun contenu disponible</h2>
            <% } %>

            <% if (blogPost && blogPost.userid) { %>
              <div class="mt-4 inline-flex items-center rounded-xl bg-[#eff8ff] px-3 py-2 text-sm font-semibold text-[#2d7fac]">👤 <span class="ml-2">Posted by <%= blogPost.userid.username %> on <%= blogPost.datePosted.toDateString() %></span></div>
            <% } %>

            <article class="mt-6 rounded-2xl border border-[#d2e9f7] bg-[#f8fcff] p-5">
              <% if (typeof blogPost !== 'undefined' && blogPost) { %>
                <h3 class="text-xl font-extrabold text-[#143b57]"><%= blogPost.title %></h3>
                <p class="mt-3 whitespace-pre-line leading-relaxed text-[#4f7188]"><%= blogPost.body %></p>
                <div class="mt-5 rounded-xl bg-[#1f3b56] px-4 py-3 text-xs text-[#cbe9ff]">
                  // Exemple code robot
                  <br />const robot = new Robot();
                  <br />robot.learn('line follower');
                </div>
                <% if (loggedIn && blogPost.userid && String(loggedIn) === String(blogPost.userid._id)) { %>
                  <form action="/posts/delete/<%= blogPost._id %>" method="POST" class="mt-5">
                    <button type="submit" class="rounded-xl bg-[#ef8f59] px-5 py-2 text-sm font-extrabold text-white transition hover:bg-[#de7b44]" onclick="return confirm('Supprimer ce post ?');">Supprimer ce post</button>
                  </form>
                <% } %>
              <% } else { %>
                <p class="text-[#4f7188]">Post introuvable</p>
              <% } %>
            </article>
          </div>

          <div class="border-l border-[#e3f1fa] bg-[#f0f9ff] p-5 sm:p-8">
            <img src="<%= headerImage %>" alt="Post visual" class="w-full rounded-2xl border border-[#d2e9f7] bg-white p-2" />
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
