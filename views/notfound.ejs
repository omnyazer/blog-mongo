<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blog Mongo | Not Found</title>
    <link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: { sans: ['Manrope', 'ui-sans-serif', 'system-ui'] }
          }
        }
      };
    </script>
  </head>
  <body class="min-h-screen bg-[#eef7fc] font-sans text-[#163752]">
    <div class="absolute inset-x-0 top-0 -z-10 h-[420px] bg-[radial-gradient(circle_at_20%_0%,#d8f0ff,transparent_48%),radial-gradient(circle_at_80%_0%,#e1f4ff,transparent_52%)]"></div>

    <%- include('layouts/navbar') %>

    <main class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
      <section class="rounded-[28px] border border-[#d7ebf7] bg-white p-8 text-center shadow-[0_18px_40px_-30px_rgba(44,116,160,0.45)]">
        <img src="/assets/img/404Robot.png" alt="Not found robot" class="mx-auto mb-6 w-full max-w-md rounded-xl border border-[#d2e9f7]" />
        <h1 class="text-3xl font-extrabold text-[#12344e] sm:text-4xl">404 Not Found Resource</h1>
        <p class="mt-3 text-[#4f7188]">No resources match your request</p>
        <p class="mt-2 text-sm text-[#60829a]">The page you are looking for does not exist.</p>
        <a href="/" class="mt-6 inline-flex rounded-xl bg-[#58b8e8] px-5 py-3 text-sm font-extrabold text-white transition hover:bg-[#419fd0]">Back to Home</a>
      </section>
    </main>
  </body>
</html>
